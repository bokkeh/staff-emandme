generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  employee Employee?
}

// ─── Core Domain ─────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

model Employee {
  id                 String         @id @default(cuid())
  userId             String?        @unique
  firstName          String
  lastName           String
  preferredName      String?
  email              String         @unique
  phone              String?
  role               Role           @default(STAFF)
  jobTitle           String?
  department         String?
  hourlyRateCents    Int?
  managerId          String?
  startDate          DateTime?
  birthMonth         Int?
  birthDay           Int?
  birthYear          Int?
  homeAddress        String?
  emergencyContactName String?
  emergencyContactPhone String?
  emergencyContactRelation String?
  emergencyContactNotes String?
  status             EmployeeStatus @default(ACTIVE)
  profilePhotoUrl    String?
  preferredWorkHours String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user            User?           @relation(fields: [userId], references: [id])
  manager         Employee?       @relation("ManagerReports", fields: [managerId], references: [id])
  reports         Employee[]      @relation("ManagerReports")
  timeEntries     TimeEntry[]
  activeTimer     ActiveTimer?
  approvedEntries TimeEntry[]     @relation("ApprovedBy")
  payrollSummaries PayrollSummary[]
  pets            Pet[]
  expenses        Expense[]
}

model Pet {
  id         String   @id @default(cuid())
  employeeId String
  name       String
  type       String
  breed      String?
  notes      String?
  photoUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─── Time Tracking ────────────────────────────────────────────────────────────

model TimeCategory {
  id           String   @id @default(cuid())
  name         String   @unique
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  timeEntries  TimeEntry[]
  activeTimers ActiveTimer[]
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum TimeEntrySource {
  TIMER
  MANUAL
  ADMIN_EDIT
}

model TimeEntry {
  id              String          @id @default(cuid())
  employeeId      String
  categoryId      String
  payPeriodId     String?
  entryDate       DateTime        @db.Date
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  note            String?
  source          TimeEntrySource @default(MANUAL)
  status          TimeEntryStatus @default(DRAFT)
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  editNote        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  employee   Employee     @relation(fields: [employeeId], references: [id])
  category   TimeCategory @relation(fields: [categoryId], references: [id])
  payPeriod  PayPeriod?   @relation(fields: [payPeriodId], references: [id])
  approvedBy Employee?    @relation("ApprovedBy", fields: [approvedById], references: [id])
}

model ActiveTimer {
  id         String   @id @default(cuid())
  employeeId String   @unique
  categoryId String
  startedAt  DateTime @default(now())
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee     @relation(fields: [employeeId], references: [id])
  category TimeCategory @relation(fields: [categoryId], references: [id])
}

// ─── Pay Periods ─────────────────────────────────────────────────────────────

enum PayPeriodType {
  WEEKLY
  BIWEEKLY
  SEMIMONTHLY
}

enum PayPeriodStatus {
  OPEN
  PROCESSING
  CLOSED
}

model PayPeriod {
  id        String          @id @default(cuid())
  startDate DateTime        @db.Date
  endDate   DateTime        @db.Date
  type      PayPeriodType   @default(BIWEEKLY)
  status    PayPeriodStatus @default(OPEN)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  timeEntries      TimeEntry[]
  payrollSummaries PayrollSummary[]
  expenses         Expense[]
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REIMBURSED
  REJECTED
}

model Expense {
  id              String        @id @default(cuid())
  employeeId      String
  payPeriodId     String?
  expenseDate     DateTime      @db.Date
  merchant        String
  category        String
  description     String?
  amountCents     Int
  isBillable      Boolean       @default(false)
  projectName     String?
  receiptImageUrl String?       @db.Text
  status          ExpenseStatus @default(DRAFT)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  employee Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payPeriod PayPeriod? @relation(fields: [payPeriodId], references: [id], onDelete: SetNull)

  @@index([employeeId, expenseDate])
  @@index([payPeriodId, status])
}

model PayrollSummary {
  id              String   @id @default(cuid())
  employeeId      String
  payPeriodId     String
  regularMinutes  Int      @default(0)
  overtimeMinutes Int      @default(0)
  approvedMinutes Int      @default(0)
  pendingMinutes  Int      @default(0)
  rejectedMinutes Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id])
  payPeriod PayPeriod @relation(fields: [payPeriodId], references: [id])

  @@unique([employeeId, payPeriodId])
}

// ─── Settings ─────────────────────────────────────────────────────────────────

model AppSettings {
  id                    String        @id @default(cuid())
  payPeriodType         PayPeriodType @default(BIWEEKLY)
  overtimeWeeklyHours   Int           @default(40)
  birthdaysVisibleToAll Boolean       @default(false)
  updatedAt             DateTime      @updatedAt
}
